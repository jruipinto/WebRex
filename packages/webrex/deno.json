{
  "version": "2.0.0-rc67",
  "license": "AGPL-3.0-only",
  "nodeModulesDir": "auto",
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "dom"
    ]
  },
  "unstable": [
    "raw-imports",
    "sloppy-imports",
    "kv"
  ],
  "tasks": {
    "start": "deno run -A src/main.ts",
    "dev": "deno run -A --watch src/main.ts",
    "pack-ui": "deno run -A scripts/compress-static-assets.ts",
    "compile": "deno task pack-ui && deno compile --icon favicon.ico -A --include tmp  --output dist/WebRex src/main.ts"
  },
  "imports": {
    "@core/": "./src/core/",
    "@features/": "./src/features/",
    "@middleware/": "./src/middleware/",
    "@models/": "../webrex-contracts/models/",
    "@deno/kv": "npm:@deno/kv@~0.13.0",
    "@hono/node-server": "npm:@hono/node-server@~1.19.7",
    "@ngrok/ngrok": "npm:@ngrok/ngrok@~1.7.0",
    "@olli/kvdex": "jsr:@olli/kvdex@~3.4.2",
    "arktype": "npm:arktype@^2.1.29",
    "esbuild-wasm": "https://deno.land/x/esbuild@v0.27.3/wasm.js",
    "hono": "npm:hono@~4.11.3",
    "object-deep-compare": "npm:object-deep-compare",
    "qrcode-terminal": "npm:qrcode-terminal@~0.12.0",
    "rxjs": "npm:rxjs@~7.8.2",
    "tar": "npm:tar@~7.5.2"
  }
}